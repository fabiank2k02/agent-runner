{
  "name": "agent-runner-dashboard",
  "private": true,
  "type": "module",
  "scripts": {
    "wrangler": "sh ./scripts/wrangler.sh",
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "deploy": "npm run build && sh ./scripts/wrangler.sh pages deploy dist --project-name agent-runner-dashboard",
    "preview": "npm run build && sh ./scripts/wrangler.sh pages dev dist",
    "screenshot": "node scripts/capture-screenshots.mjs",
    "test:visual": "node scripts/visual-compare.mjs",
    "db:create": "sh ./scripts/wrangler.sh d1 create agent-runner-dashboard",
    "db:migrate:local": "sh ./scripts/wrangler.sh d1 migrations apply agent-runner-dashboard --local",
    "db:migrate": "sh ./scripts/wrangler.sh d1 migrations apply agent-runner-dashboard --remote"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.61.0",
    "pngjs": "^7.0.0",
    "vite": "^8.0.16",
    "wrangler": "^4.100.0"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "d3-shape": "^3.2.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.184.0"
  }
}
